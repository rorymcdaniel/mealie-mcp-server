# Mealie instance base URL (required)
MEALIE_URL=http://localhost:9925

# Mealie API token (required)
# Generate one at: <your-mealie-url>/user/profile/api-tokens
MEALIE_API_TOKEN=your-api-token-here

# --- HTTP transport only ---

# Public URL of this server (required for HTTP mode)
# Used as OAuth issuer URL and for metadata endpoint discovery
MCP_SERVER_URL=https://your-domain.example.com

# Port for the HTTP server (default: 3000)
# PORT=3000

# --- Docker Compose only ---

# Name of the external Docker network your Mealie container is on.
# Only needed if Mealie and the MCP server are in separate Compose projects.
# Find it with: docker network ls
# MEALIE_DOCKER_NETWORK=docker_mealie_network
